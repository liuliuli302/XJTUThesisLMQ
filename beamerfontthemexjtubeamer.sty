\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{beamerfontthemexjtubeamer}[2023/05/28 v1.0.0 xjtubeamer font theme]

%%%%%%%%%%%
%% FONTS %%
%%%%%%%%%%%

\RequirePackage{silence}
\RequirePackage{unicode-math}

\WarningFilter{latexfont}{Font shape}
\usefonttheme{professionalfonts}
\usefonttheme{structurebold}
\setbeamerfont{part name}{size=\normalsize}
\setbeamerfont{section name}{size=\normalsize}
\setbeamerfont{subsection name}{size=\normalsize}
\setbeamerfont{footnote}{size=\scriptsize}

\newcommand{\xjtubeamer@fontspath}{Materials/Fonts/}
\newcommand{\xjtubeamer@setupmainfont}{%
  \IfFileExists{Materials/Fonts/times.ttf}{%
    \setmainfont[
      Path=\xjtubeamer@fontspath,
      UprightFont=times.ttf,
      BoldFont=timesbd.ttf,
      ItalicFont=timesi.ttf,
      BoldItalicFont=timesbi.ttf
    ]{times.ttf}%
    \setsansfont[
      Path=\xjtubeamer@fontspath,
      UprightFont=times.ttf,
      BoldFont=timesbd.ttf,
      ItalicFont=timesi.ttf,
      BoldItalicFont=timesbi.ttf
    ]{times.ttf}%
  }{%
    \IfFontExistsTF{XITS}{%
      \setmainfont{XITS}%
      \setsansfont{XITS}%
    }{%
      \setmainfont{Latin Modern Roman}%
      \setsansfont{Latin Modern Sans}%
    }%
  }%
}
\newcommand{\xjtubeamer@setupcjkfont}{%
  \IfFileExists{Materials/Fonts/fzsong.ttf}{%
    \setCJKmainfont[AutoFakeBold=true,Path=\xjtubeamer@fontspath]{fzsong.ttf}%
  }{%
    \setCJKmainfont[AutoFakeBold=true]{FandolSong}%
  }%
  \IfFileExists{Materials/Fonts/fzhei.ttf}{%
    \setCJKsansfont[AutoFakeBold=false,Path=\xjtubeamer@fontspath]{fzhei.ttf}%
  }{%
    \setCJKsansfont[AutoFakeBold=false]{FandolHei}%
  }%
  \IfFontExistsTF{FandolKai-Regular.otf}{%
    \newCJKfontfamily{\kaiti}{FandolKai-Regular.otf}%
  }{%
    \let\kaiti\CJKrmfamily
  }%
}
\newcommand{\xjtubeamer@setupmathfont}{%
  \IfFileExists{Materials/Fonts/xits-math.otf}{%
    \setmathfont[Path=\xjtubeamer@fontspath,BoldFont=xits-mathbold.otf]{xits-math.otf}%
    \setmathfont[Path=\xjtubeamer@fontspath,range={\mathcal,\mathbfcal},StylisticSet=1,BoldFont=xits-mathbold.otf]{xits-math.otf}%
  }{%
    \IfFontExistsTF{XITS Math}{%
      \setmathfont{XITS Math}%
      \setmathfont[range={\mathcal,\mathbfcal},StylisticSet=1]{XITS Math}%
    }{%
      \IfFontExistsTF{XITSMath-Regular.otf}{%
        \setmathfont{XITSMath-Regular.otf}[BoldFont=XITSMath-Bold.otf]%
        \setmathfont[range={\mathcal,\mathbfcal},StylisticSet=1]{XITSMath-Regular.otf}[BoldFont=XITSMath-Bold.otf]%
      }{%
        \IfFontExistsTF{STIX Two Math}{%
          \setmathfont{STIX Two Math}%
        }{%
          \IfFontExistsTF{TeX Gyre Termes Math}{%
            \setmathfont{TeX Gyre Termes Math}%
          }{%
            \setmathfont{latinmodern-math.otf}%
          }%
        }%
      }%
    }%
  }%
}
\xjtubeamer@setupcjkfont
\xjtubeamer@setupmainfont
\xjtubeamer@setupmathfont



\endinput

